# Copy this file to .env and fill in your keys

# Anthropic (Claude) — used for meeting summaries
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Google OAuth credentials — used to save notes to Google Drive
# See README.md for step-by-step setup instructions
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Session cookie signing secret (any long random string)
SESSION_SECRET=

# --- Cloud deployment only (leave empty for local use) ---
# Public URL of the deployed app, e.g. https://nes-meeting-recorder.onrender.com
BASE_URL=
# Turso database (https://turso.tech) — locally a data.db file is used instead
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Optional
PORT=3000
DRIVE_FOLDER_NAME=Meeting Notes
